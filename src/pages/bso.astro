---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Banda sonora | Segundo Cielo Dossier">
  <section id="lucia">
    <a href="/" class="h1">
      <hgroup>
        <h1>Segundo Cielo</h1>
      </hgroup>
    </a>

    <div class="bso-description">
      <p class="first-p">
        <img
          src="https://web.archive.org/web/20040520174007if_/http://www.geocities.com:80/nightmarecreatures86/music.gif"
          alt=""
          width="100%"
        />
        La propuesta sonora del cortometraje se construye desde una idea central:
        la tecnología como presencia constante. El sonido del ordenador —su zumbido,
        el ventilador, los pequeños clics— no funciona solo como ambiente, sino como
        un elemento narrativo que acompaña y define el estado de la protagonista.
        Estos sonidos, propios de la tecnología de la época, se integran de forma
        orgánica con el espacio doméstico, generando una base continua sobre la que
        se apoya toda la atmósfera. A partir de ahí, la banda sonora se articula mediante
        drones y capas sostenidas que no buscan imponerse, sino amplificar esa sensación
        de permanencia, como si el propio entorno estuviera respirando.
      </p>

      <div class="keyboard" id="piano-keyboard">
        <div class="key white" data-note="261.63"></div>
        <div class="key black" data-note="277.18"></div>
        <div class="key white" data-note="293.66"></div>
        <div class="key black" data-note="311.13"></div>
        <div class="key white" data-note="329.63"></div>
        <div class="key white" data-note="349.23"></div>
        <div class="key black" data-note="369.99"></div>
        <div class="key white" data-note="392.00"></div>
        <div class="key black" data-note="415.30"></div>
        <div class="key white" data-note="440.00"></div>
        <div class="key black" data-note="466.16"></div>
        <div class="key white" data-note="493.88"></div>

        <div class="key white" data-note="523.25"></div>
        <div class="key black" data-note="554.37"></div>
        <div class="key white" data-note="587.33"></div>
        <div class="key black" data-note="622.25"></div>
        <div class="key white" data-note="659.25"></div>
        <div class="key white" data-note="698.46"></div>
        <div class="key black" data-note="739.99"></div>
        <div class="key white" data-note="783.99"></div>
        <div class="key black" data-note="830.61"></div>
        <div class="key white" data-note="880.00"></div>
        <div class="key black" data-note="932.33"></div>
        <div class="key white" data-note="987.77"></div>
      </div>

      <p class="second-p">
        En términos musicales, la referencia se acerca a los trabajos de

        <span class="music-ref">Akira Yamaoka</span>
        en la saga Silent Hill
        <img
          src="https://blob.gifcities.org/gifcities/YIZEDB2HQSVA6LZWBLOQBU4HBI57L2X2.gif"
          alt="silent hill"
          class="sh-gif"
          id="sh-trigger"
          style="cursor: pointer;"
          title="Haz clic para jugar!"
        />

        o a las composiciones de

        <span class="music-ref">Bobby Krlic,</span>

        donde la música se diluye con el diseño sonoro hasta volverse casi
        indistinguible. El objetivo es construir un ambiente progresivamente
        opresivo, con muy pocos motivos armónicos y, cuando aparecen, que lo
        hagan de forma sutil, casi imperceptible. La música no guía
        emocionalmente de forma evidente, sino que se adhiere al espacio, a los
        silencios y a los gestos mínimos, reforzando la sensación de encierro y
        acompañando la deriva de la protagonista hacia un estado cada vez más
        absorbente.

        <img
          src="https://web.archive.org/web/20010809113717if_/http://espanol.geocities.com:80/ilselein/_derived/radio.htm_cmp_auto110_bnr.gif"
          alt=""
          width="50%"
        />

        <img
          src="https://web.archive.org/web/20091026194931im_/http://geocities.com/gifs48/img49.gif"
          alt=""
        />

        <img
          src="https://blob.gifcities.org/gifcities/NONADXQSIJVAKGQ3C5U56QS4OCDUMTEL.gif"
          alt=""
          class="rock-on"
        />
      </p>
    </div>
  </section>

  <audio id="miAudio" src="/assets/eclipse.mp3" loop autoplay></audio>

  <div class="reproductor-cutre">
    <div class="pantalla-digital">
      <span id="estado">STOPPED</span> | <span id="porcentaje">70%</span>
    </div>
    <img
      src="https://web.archive.org/web/20090725010258im_/http://www.geocities.com/trudytoo.geo/gifs/speaker2.gif"
      alt=""
      width="100%"
    />

    <div class="botonera">
      <button id="btnMute" class="btn-win95">▶︎</button>
      <input
        type="range"
        id="sliderVolumen"
        class="barra-volumen"
        min="0"
        max="100"
        value="70"
      />
    </div>
    <div style="font-size: 9px; margin-top: 5px; text-align: center">
      WebAmp v1.0
    </div>
  </div>

  <div class="modal-sh-overlay" id="sh-modal">
    <div class="modal-sh-content">
      <div class="modal-sh-header">
        <span>SILENT_HILL.EXE</span>
        <button id="btn-cerrar-sh">X</button>
      </div>
      <div class="modal-sh-body">
        <div id="iframe-container"></div>
      </div>
    </div>
  </div>

  <style>
    .rock-on {
      width: 200px;
      transform: translate(50px, 60px);
    }
    .bso-description p {
      background-color: var(--color-black);
      color: var(--color-yellow);
      font-size: 1.5rem;
    }
    .bso-description .first-p {
      margin-top: 3rem;
    }
    .bso-description .second-p {
      margin-top: 1rem;
    }

    .second-p {
      margin-bottom: 5rem;
    }
    .music-ref {
      background-color: var(--color-blue-bg);
      color: var(--color-white);
      font-weight: bold;
      font-size: 1.5rem;
      text-transform: uppercase;
      letter-spacing: -1px;
      font-style: italic;
      font-family: Arial, Helvetica, sans-serif;
    }
    .sh-gif {
      display: inline;
    }
    .reproductor-cutre {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background-color: #c0c0c0; /* Gris Windows 95 */
      border-top: 3px solid #fff;
      border-left: 3px solid #fff;
      border-bottom: 3px solid #555;
      border-right: 3px solid #555;
      padding: 10px;
      font-family: "Arial", sans-serif;
      color: #000;
      width: 180px;
      z-index: 1000;
    }

    @media (max-width: 900px) {
      .reproductor-cutre {
        bottom: 10px;
        left: 2%;
        width: 100%;
        display: flex;
        max-height: 80px;
        scale: 0.7;

        img {
          scale: 0.8;
        }
      }

      .second-p {
        margin-bottom: 9rem;
      }
    }

    .pantalla-digital {
      background-color: #000;
      color: #00ff00; /* Letras verdes de Matrix */
      font-family: "Courier New", monospace;
      padding: 5px;
      margin-bottom: 10px;
      font-size: 14px;
      border: 2px inset #fff;
    }

    .botonera {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 5px;
    }

    /* Botones estilo Windows 95 */
    .btn-win95 {
      background-color: #c0c0c0;
      border-top: 2px solid #fff;
      border-left: 2px solid #fff;
      border-bottom: 2px solid #000;
      border-right: 2px solid #000;
      padding: 5px 10px;
      font-weight: bold;
      height: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 3rem;
      cursor: pointer;
      font-size: 2rem;
      border-radius: 100%;
      color: lime;
    }

    .btn-win95:active {
      border-top: 2px solid #000;
      border-left: 2px solid #000;
      border-bottom: 2px solid #fff;
      border-right: 2px solid #fff;
    }

    .barra-volumen {
      width: 70px;
      cursor: pointer;
    }

    /* ESTILOS DEL TECLADO CUTRE */
    .keyboard {
      display: flex;
      position: relative;
      height: 150px;
      justify-content: center;
      max-width: 680px;
      margin: 2rem auto;
    }

    .key {
      position: relative;
      cursor: pointer;
      user-select: none;
    }

    .white {
      height: 100%;
      width: 35px;
      background-color: #ffffff;
      border: 1px solid #000;
      z-index: 1;
    }

    /* HOVER EN BLANCAS */
    .white:hover {
      background-color: #e0f7fa; /* Un cian muy sutil para insinuar */
    }

    /* Al pulsar se vuelve roja */
    .white:active,
    .white.active {
      background-color: cyan !important;
    }

    /* Posicionamiento de las teclas negras */
    .black {
      height: 60%;
      width: 22px;
      background-color: #000000;
      border: 1px solid #000;
      z-index: 2;
      margin-left: -11px;
      margin-right: -11px;
    }

    /* HOVER EN NEGRAS */
    .black:hover {
      background-color: #006064; /* Cian oscuro */
    }

    .black:active,
    .black.active {
      background-color: rgb(0, 208, 208) !important;
      border-color: black;
    }

    /* CSS PARA EL MODAL DEL JUEGO */
    .modal-sh-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(0, 0, 0, 0.85);
      z-index: 9999999;
      display: none;
      justify-content: center;
      align-items: center;
    }

    .modal-sh-content {
      background: #c0c0c0;
      border: 4px outset #fff;
      width: fit-content;
      box-shadow: 10px 10px 0px #000;
      font-family: "Courier New", Courier, monospace;
    }

    .modal-sh-header {
      background: #000080;
      color: #fff;
      padding: 4px 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: bold;
      font-size: 0.9rem;
    }

    .modal-sh-header button {
      background: #c0c0c0;
      border: 2px outset #fff;
      font-weight: bold;
      cursor: pointer;
      font-family: Arial, sans-serif;
      font-size: 0.8rem;
      line-height: 1;
      padding: 1px 4px;
    }

    .modal-sh-header button:active {
      border-style: inset;
    }

    .modal-sh-body {
      padding: 10px;
      background: #000;
    }

    /* Ajustar el iframe a las dimensiones que pedías */
    iframe {
      display: block;
      border: none;
    }
  </style>

  <script>
    // 1. LÓGICA DEL REPRODUCTOR PRINCIPAL DE AUDIO
    function setupAudio() {
      const audio = document.getElementById("miAudio") as HTMLAudioElement;
      const btnMute = document.getElementById("btnMute") as HTMLButtonElement;
      const sliderVolumen = document.getElementById(
        "sliderVolumen",
      ) as HTMLInputElement;
      const porcentaje = document.getElementById("porcentaje") as HTMLElement;
      const estado = document.getElementById("estado") as HTMLElement;

      if (!audio || !btnMute || !sliderVolumen || !porcentaje || !estado)
        return;

      audio.volume = 0.5;

      function intentarReproducir() {
        audio
          .play()
          .then(() => {
            if (btnMute) btnMute.textContent = "။";
            if (estado) {
              estado.textContent = "PLAYING";
              estado.style.color = "#00FF00";
            }
          })
          .catch(() => {
            const playOnInteraction = () => {
              audio
                .play()
                .then(() => {
                  if (btnMute) btnMute.textContent = "။";
                  if (estado) {
                    estado.textContent = "PLAYING";
                    estado.style.color = "#00FF00";
                  }
                })
                .catch(() => {});
            };
            document.addEventListener("scroll", playOnInteraction, {
              once: true,
            });
            document.addEventListener("click", playOnInteraction, {
              once: true,
            });
          });
      }

      intentarReproducir();

      btnMute.addEventListener("click", function () {
        if (audio.paused) {
          audio.play();
          btnMute.textContent = "။";
          estado.textContent = "PLAYING";
          estado.style.color = "#00FF00";
        } else {
          audio.pause();
          btnMute.textContent = "▶︎";
          estado.textContent = "STOPPED";
          estado.style.color = "#FF0000";
        }
      });

      sliderVolumen.addEventListener("input", function () {
        const valor = sliderVolumen.value;
        audio.volume = parseFloat(valor) / 100;
        porcentaje.textContent = valor + "%";
      });
    }

    // 2. LÓGICA DEL SINTETIZADOR WEB AUDIO API CON BARRIDO
    function setupTeclado() {
      let audioCtx: AudioContext | null = null;
      let isDragging = false;

      function getAudioCtx() {
        if (!audioCtx) {
          // @ts-ignore
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        return audioCtx;
      }

      function reproducirNota(frequency: number) {
        const ctx = getAudioCtx();
        const oscillator = ctx.createOscillator();
        const gainNode = ctx.createGain();

        oscillator.type = "sawtooth";
        oscillator.frequency.value = frequency;

        gainNode.gain.setValueAtTime(0, ctx.currentTime);
        gainNode.gain.linearRampToValueAtTime(0.3, ctx.currentTime + 0.05);
        gainNode.gain.exponentialRampToValueAtTime(
          0.001,
          ctx.currentTime + 1.2,
        );

        oscillator.connect(gainNode);
        gainNode.connect(ctx.destination);

        oscillator.start();
        oscillator.stop(ctx.currentTime + 1.2);
      }

      const keys = document.querySelectorAll(".key");

      function triggerKey(key: Element) {
        const noteStr = key.getAttribute("data-note");
        if (noteStr) {
          reproducirNota(parseFloat(noteStr));
          key.classList.add("active");
          setTimeout(() => key.classList.remove("active"), 300);
        }
      }

      document.addEventListener("mousedown", () => {
        isDragging = true;
      });
      document.addEventListener("mouseup", () => {
        isDragging = false;
      });

      keys.forEach((key) => {
        key.addEventListener("mousedown", (e) => {
          e.preventDefault();
          triggerKey(key);
        });

        key.addEventListener("mouseenter", () => {
          if (isDragging) {
            triggerKey(key);
          }
        });
      });

      const keyboard = document.getElementById("piano-keyboard");
      if (keyboard) {
        keyboard.addEventListener(
          "touchstart",
          (e) => {
            e.preventDefault();
            handleTouch(e);
          },
          { passive: false },
        );

        keyboard.addEventListener(
          "touchmove",
          (e) => {
            e.preventDefault();
            handleTouch(e);
          },
          { passive: false },
        );
      }

      let lastTouchedKey: Element | null = null;

      function handleTouch(e: TouchEvent) {
        const touch = e.touches[0];
        const element = document.elementFromPoint(touch.clientX, touch.clientY);

        if (
          element &&
          element.classList.contains("key") &&
          element !== lastTouchedKey
        ) {
          lastTouchedKey = element;
          triggerKey(element);
        }
      }

      window.addEventListener("touchend", () => {
        lastTouchedKey = null;
      });
    }

    // 3. NUEVA LÓGICA: EJECUTAR SILENT HILL EN MODAL
    function setupSilentHill() {
      const trigger = document.getElementById("sh-trigger");
      const modal = document.getElementById("sh-modal");
      const btnCerrar = document.getElementById("btn-cerrar-sh");
      const container = document.getElementById("iframe-container");

      if (!trigger || !modal || !btnCerrar || !container) return;

      const iframeHTML = `<iframe src="https://www.retrogames.cc/embed/41684-silent-hill.html" width="600" height="450" frameborder="no" allowfullscreen="true" webkitallowfullscreen="true" mozallowfullscreen="true" scrolling="no"></iframe>`;

      trigger.addEventListener("click", () => {
        container.innerHTML = iframeHTML; // Insertamos el iframe
        modal.style.display = "flex";
      });

      function cerrarModal() {
        modal!.style.display = "none";
        container!.innerHTML = ""; // Vaciamos el iframe para detener el sonido del emulador
      }

      btnCerrar.addEventListener("click", cerrarModal);

      modal.addEventListener("click", (e) => {
        if (e.target === modal) cerrarModal();
      });
    }

    setupAudio();
    setupTeclado();
    setupSilentHill();

    document.addEventListener("astro:after-swap", () => {
      setupAudio();
      setupTeclado();
      setupSilentHill();
    });
  </script>
</Layout>
