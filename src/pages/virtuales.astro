---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Espacios virtuales | Segundo Cielo Dossier">
  <section id="sinopsis">
    <a href="/" class="h1">
      <hgroup>
        <h1>Segundo Cielo</h1>
      </hgroup>
    </a>

    <div class="intro-box">
      <p>
        A diferencia del presente, donde la relación con internet está
        atravesada por la sospecha constante —estafas, inteligencias
        artificiales, deepfakes—, hubo un momento en el que navegar
        implicaba una entrega distinta. Existía una mayor disposición a
        dejarse arrastrar por lo desconocido, a dudar menos de lo que se
        veía. En ese contexto, estos entornos funcionan para la
        protagonista como un refugio: tras una pérdida dolorosa, encuentra
        en ellos una especie de segunda casa, un lugar donde volcar su
        atención y disociar, oscilando entre el consuelo y una progresiva
        desconexión de lo realidad física.
      </p>

      <div class="galeria-2003-container">
        <table
          border="5"
          cellpadding="10"
          cellspacing="5"
          style="background-color: #c0c0c0"
          class="retro-table"
        >
          <tr>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev1.png" alt="Foto 1" class="img-miniatura gallery-trigger" data-url="/assets/ev1.png" style="border: 3px solid #ff00ff; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev2.png" alt="Foto 2" class="img-miniatura gallery-trigger" data-url="/assets/ev2.png" style="border: 3px solid #ffff00; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev3.png" alt="Foto 3" class="img-miniatura gallery-trigger" data-url="/assets/ev3.png" style="border: 3px solid #00ffff; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev4.png" alt="Foto 4" class="img-miniatura gallery-trigger" data-url="/assets/ev4.png" style="border: 3px solid #00ff00; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev5.png" alt="Foto 5" class="img-miniatura gallery-trigger" data-url="/assets/ev5.png" style="border: 3px solid #ff0000; padding: 2px; width: 100px; height: 100px;" />
            </td>
          </tr>
          <tr>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev6.png" alt="Foto 6" class="img-miniatura gallery-trigger" data-url="/assets/ev6.png" style="border: 3px solid #ffffff; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev7.png" alt="Foto 7" class="img-miniatura gallery-trigger" data-url="/assets/ev7.png" style="border: 3px solid #ff00ff; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev8.png" alt="Foto 8" class="img-miniatura gallery-trigger" data-url="/assets/ev8.png" style="border: 3px solid #ffff00; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev9.png" alt="Foto 9" class="img-miniatura gallery-trigger" data-url="/assets/ev9.png" style="border: 3px solid #00ffff; padding: 2px; width: 100px; height: 100px;" />
            </td>
            <td align="center" valign="middle" style="background-color: #111; border: 2px inset #fff">
              <img src="/assets/ev10.png" alt="Foto 10" class="img-miniatura gallery-trigger" data-url="/assets/ev10.png" style="border: 3px solid #00ff00; padding: 2px; width: 100px; height: 100px;" />
            </td>
          </tr>
        </table>

        <div>
          <marquee scrollamount="20" style="background-color: #ffff00" class="click-marquee">
            <span class="click-text">*** 𝕙𝕒𝕫 𝕔𝕝𝕚𝕔𝕜 𝕖𝕟 𝕝𝕒𝕤 𝕗𝕠𝕥𝕠𝕤 𝕡𝕒𝕣𝕒 𝕧𝕖𝕣𝕝𝕒𝕤 𝕖𝕟 𝕘𝕣𝕒𝕟𝕕𝕖!!!! ***</span>
          </marquee>
        </div>
      </div>

      <p class="p2">
        Se trata de páginas de estética primitiva, construidas con lógicas
        visuales caóticas, gifs animados y una apariencia casi amateur que
        resulta, sin embargo, profundamente absorvente. Bajo esa
        superficie aparentemente ingenua emergen discursos extraños:
        mezclas de espiritualidad dispersa, teorías conspiranoicas y
        estructuras de pensamiento cercanas a lo sectario. Todo parece
        incompleto, fragmentado, como si hubiera un sentido oculto al que
        solo se accede permaneciendo más tiempo del debido. Esa cualidad
        las convierte en espacios atrapantes, capaces de absorber al
        usuario en recorridos interminables, donde cada enlace promete una
        revelación que nunca termina de llegar.
      </p>
    </div>
  </section>

  <div id="visor-superpuesto">
    <div class="contenido-visor">
      <button id="btn-prev" class="btn-retro">
        <img src="https://blob.gifcities.org/gifcities/5TFYOKH64KJEKHILSIWYGXJGU6FB2ZNU.gif" alt="" />
      </button>
      <button id="btn-next" class="btn-retro">
        <img src="https://blob.gifcities.org/gifcities/5JU6EVRUZYPEXZ4MKJOEPSVD3SKKCSZK.gif" alt="" />
      </button>
      <button id="btn-cerrar" class="btn-retro">X</button>

      <img id="foto-grande" src="#" alt="Foto en grande" />

      <div id="contador-visor">
        (Visor de Imágenes v1.0)
      </div>
    </div>
  </div>

  <style>
    p{
      background-color: rebeccapurple;
      font-size: 1.8rem;
    }

    .p2{
      font-family: Arial, Helvetica, sans-serif;
      margin-bottom: 5rem;
      font-size: 1.5rem;
      transform: translateY(-50px);
    }

    .intro-box p {
      margin-top: 4rem;
    }
    .windows-gallery {
      background-color: var(--color-blue-bg);
      border: 2px solid var(--color-white);
      padding: 1rem;
      margin: 2rem 0 0 0;
    }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 1rem;
    }
    .gallery-item {
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.2s;
    }
    .gallery-item:hover {
      border-color: var(--color-yellow);
    }
    .gallery-item img {
      width: 100%;
      height: 150px;
      object-fit: cover;
    }

    /* Visor styles */
    .visor-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.9);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 2000;
    }
    .visor-window {
      background: #c0c0c0; /* Classic Win95 grey */
      border: 3px solid;
      border-color: #fff #808080 #808080 #fff;
      padding: 2px;
      max-width: 90%;
      max-height: 90%;
      display: flex;
      flex-direction: column;
    }
    .visor-header {
      background: var(--color-blue);
      color: var(--color-white);
      padding: 3px 10px;
      font-family: var(--font-sans);
      font-weight: bold;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .visor-close {
      background: #c0c0c0;
      border: 2px solid;
      border-color: #fff #808080 #808080 #fff;
      width: 20px;
      height: 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      color: var(--color-black);
      font-size: 14px;
    }
    .visor-content {
      padding: 10px;
      display: flex;
      justify-content: center;
    }
    .visor-content img {
      max-width: 100%;
      max-height: 70vh;
      border: 2px solid #808080;
    }
    .retro-table {
      border-color: #ffffff #555555 #555555 #ffffff;
      margin: 0 auto;
      width: 100%;
    }
    .click-marquee {
      border: 1px solid #000;
      margin-top: 5px;
    }
    .click-text {
      color: #000;
      font-weight: bold;
      font-size: 20px;
      font-family: Arial;
    }
    #visor-superpuesto {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.85);
      z-index: 9999;
      text-align: center;
      overflow: auto;
      padding-top: 50px;
    }

    .contenido-visor {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background-color: #c0c0c0;
      border-top: 4px solid #fff;
      border-left: 4px solid #fff;
      border-bottom: 4px solid #555;
      width: 70%;
      height: 80vh;
      border-right: 4px solid #555;
      padding: 40px 10px 10px 10px;
      box-shadow: 10px 10px 0px rgba(0, 0, 0, 0.5);
    }

    #foto-grande {
      max-width: 100%;
      max-height: 90%;
      border: 5px inset #fff;
    }

    .btn-retro {
      background-color: #c0c0c0;
      border-top: 2px solid #fff;
      border-left: 2px solid #fff;
      border-bottom: 2px solid #000;
      border-right: 2px solid #000;
      color: #000;
      font-family: Arial, sans-serif;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
      padding: 2px 8px;
      position: absolute;
    }

    .btn-retro:active {
      border-top: 2px solid #000;
      border-left: 2px solid #000;
      border-bottom: 2px solid #fff;
      border-right: 2px solid #fff;
    }

    #btn-cerrar {
      top: 5px;
      right: 5px;
      background-color: red;
    }

    #btn-prev {
      all: unset;
      cursor: pointer;
      position: fixed;
      scale: 1.5;
      top: 50%;
      transform: translateY(-50%);
      left: -10rem;
    }

    #btn-next {
      all: unset;
      cursor: pointer;
      position: fixed;
      top: 50%;
      height: 5rem;
      scale: 1.5;
      transform: translateY(-50%);
      right: -10rem;
    }

    .img-miniatura {
      cursor: pointer;
      transition: transform 0.2s;
    }

    .img-miniatura:hover {
      transform: scale(1.05);
    }
  </style>

  <script>
    function setupGallery() {
      const visor = document.getElementById("visor-superpuesto") as HTMLElement;
      const fotoGrande = document.getElementById("foto-grande") as HTMLImageElement;
      const contadorVisor = document.getElementById("contador-visor") as HTMLElement;
      const btnCerrar = document.getElementById("btn-cerrar");
      const btnNext = document.getElementById("btn-next");
      const btnPrev = document.getElementById("btn-prev");

      const listaFotos = [
        "/assets/ev1.png",
        "/assets/ev2.png",
        "/assets/ev3.png",
        "/assets/ev4.png",
        "/assets/ev5.png",
        "/assets/ev6.png",
        "/assets/ev7.png",
        "/assets/ev8.png",
        "/assets/ev9.png",
        "/assets/ev10.png",
      ];

      let indiceActual = 0;

      function actualizarImagen() {
        const ruta = listaFotos[indiceActual];
        fotoGrande.src = ruta;
        contadorVisor.innerHTML = `Archivo: ${ruta.split("/").pop()} | Foto ${indiceActual + 1} de ${listaFotos.length}`;
      }

      function mostrarFoto(urlFotoGrande: string) {
        indiceActual = listaFotos.indexOf(urlFotoGrande);
        actualizarImagen();
        visor.style.display = "block";
        document.body.style.overflow = "hidden";
      }

      function cerrarVisor() {
        visor.style.display = "none";
        fotoGrande.src = "";
        document.body.style.overflow = "auto";
      }

      function fotoSiguiente() {
        indiceActual = (indiceActual >= listaFotos.length - 1) ? 0 : indiceActual + 1;
        actualizarImagen();
      }

      function fotoAnterior() {
        indiceActual = (indiceActual <= 0) ? listaFotos.length - 1 : indiceActual - 1;
        actualizarImagen();
      }

      document.querySelectorAll('.gallery-trigger').forEach(el => {
        el.addEventListener('click', () => {
          const url = (el as HTMLElement).dataset.url;
          if (url) mostrarFoto(url);
        });
      });

      btnCerrar?.addEventListener('click', cerrarVisor);
      btnNext?.addEventListener('click', fotoSiguiente);
      btnPrev?.addEventListener('click', fotoAnterior);
      visor?.addEventListener('click', (e) => { if (e.target === visor) cerrarVisor(); });
    }

    setupGallery();
    document.addEventListener('astro:after-swap', setupGallery);
  </script>
</Layout>
