---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Espacios virtuales | Segundo Cielo Dossier">
  <section id="sinopsis">
    <a href="/" class="h1">
      <hgroup>
        <h1>Segundo Cielo</h1>
      </hgroup>
    </a>

    <div class="intro-box">
      <p>
        A diferencia del presente, donde la relación con internet está
        atravesada por la sospecha constante —estafas, inteligencias
        artificiales, deepfakes—, hubo un momento en el que navegar implicaba
        una entrega distinta. Existía una mayor disposición a dejarse arrastrar
        por lo desconocido, a dudar menos de lo que se veía. En ese contexto,
        estos entornos funcionan para la protagonista como un refugio: tras una
        pérdida dolorosa, encuentra en ellos una especie de segunda casa, un
        lugar donde volcar su atención y disociar, oscilando entre el consuelo y
        una progresiva desconexión de lo realidad física.
      </p>

      <div class="galeria-2003-container">
        <div class="table-responsive">
          <table
            border="5"
            cellpadding="10"
            cellspacing="5"
            style="background-color: #c0c0c0"
            class="retro-table"
          >
            <tr>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev1.png"
                  alt="Foto 1"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev1.png"
                  style="border: 3px solid #ff00ff; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev2.png"
                  alt="Foto 2"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev2.png"
                  style="border: 3px solid #ffff00; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev3.png"
                  alt="Foto 3"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev3.png"
                  style="border: 3px solid #00ffff; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev4.png"
                  alt="Foto 4"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev4.png"
                  style="border: 3px solid #00ff00; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev5.png"
                  alt="Foto 5"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev5.png"
                  style="border: 3px solid #ff0000; padding: 2px;"
                />
              </td>
            </tr>
            <tr>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev6.png"
                  alt="Foto 6"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev6.png"
                  style="border: 3px solid #ffffff; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev7.png"
                  alt="Foto 7"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev7.png"
                  style="border: 3px solid #ff00ff; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev8.png"
                  alt="Foto 8"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev8.png"
                  style="border: 3px solid #ffff00; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev9.png"
                  alt="Foto 9"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev9.png"
                  style="border: 3px solid #00ffff; padding: 2px;"
                />
              </td>
              <td
                align="center"
                valign="middle"
                style="background-color: #111; border: 2px inset #fff"
              >
                <img
                  src="/assets/ev10.png"
                  alt="Foto 10"
                  class="img-miniatura gallery-trigger"
                  data-url="/assets/ev10.png"
                  style="border: 3px solid #00ff00; padding: 2px;"
                />
              </td>
            </tr>
          </table>
        </div>

        <div>
          <marquee
            scrollamount="20"
            style="background-color: #ffff00"
            class="click-marquee"
          >
            <span class="click-text"
              >*** 𝕙𝕒𝕫 𝕔𝕝𝕚𝕔𝕜 𝕖𝕟 𝕝𝕒𝕤 𝕗𝕠𝕥𝕠𝕤 𝕡𝕒𝕣𝕒 𝕧𝕖𝕣𝕝𝕒𝕤 𝕖𝕟 𝕘𝕣𝕒𝕟𝕕𝕖!!!! ***</span
            >
          </marquee>
        </div>
      </div>

      <p>
        Se trata de páginas de estética primitiva, construidas con lógicas
        visuales caóticas, gifs animados y una apariencia casi amateur que
        resulta, sin embargo, profundamente absorbente.
      </p>

      <p class="p2">
        Bajo esa superficie aparentemente ingenua emergen discursos extraños:
        mezclas de
        <a
          href="https://www.heavenly-angels.org/english/default_en.htm"
          target="_blank"
          rel="noopener noreferrer">espiritualidad dispersa</a
        >, <a
          href="https://www.indianinthemachine.com/sylphsandcloudships.html"
          target="_blank"
          rel="noopener noreferrer">teorías conspiranoicas</a
        > y estructuras de pensamiento cercanas a lo <a
          href="https://joanocean.com/Portalopng.html"
          target="_blank"
          rel="noopener noreferrer">sectario</a
        >. Todo parece incompleto, fragmentado, como si hubiera un sentido
        oculto al que solo se accede permaneciendo más tiempo del debido. Esa
        cualidad las convierte en espacios atrapantes, capaces de absorber al
        usuario en recorridos interminables, donde cada enlace promete una
        revelación que nunca termina de llegar.
      </p>
    </div>
  </section>

  <div id="visor-superpuesto">
    <div class="contenido-visor">
      <div class="visor-header">
        <span>Visor de Imágenes v1.0</span>
        <button id="btn-cerrar" class="btn-retro">X</button>
      </div>

      <div class="visor-body">
        <button id="btn-prev" class="btn-retro btn-nav">
          <img
            src="https://blob.gifcities.org/gifcities/5TFYOKH64KJEKHILSIWYGXJGU6FB2ZNU.gif"
            alt=""
          />
        </button>

        <img id="foto-grande" src="#" alt="Foto en grande" />

        <button id="btn-next" class="btn-retro btn-nav">
          <img
            src="https://blob.gifcities.org/gifcities/5JU6EVRUZYPEXZ4MKJOEPSVD3SKKCSZK.gif"
            alt=""
          />
        </button>
      </div>

      <div id="contador-visor">(Cargando...)</div>
    </div>
  </div>

  <style>
    p {
      background-color: rebeccapurple;
      font-size: 1.8rem;
    }

    .p2 {
      font-family: Arial, Helvetica, sans-serif;
      margin-bottom: 5rem;
      font-size: 1.5rem;
      transform: translateY(-50px);
    }

    .p2 a {
      background: yellow;
      font-weight: bold;
      font-style: italic;
      cursor: pointer;
      font-size: 1.8rem;
      color: black;

      &:hover {
        background: blue;
        color: white;
      }
    }

    .intro-box p {
      margin-top: 4rem;
    }

    /* --- ESTILOS DE LA GALERÍA --- */
    .table-responsive {
      width: 100%;
      overflow-x: auto;
    }

    .retro-table {
      border-color: #ffffff #555555 #555555 #ffffff;
      margin: 0 auto;
      width: 100%;
      table-layout: fixed;
    }

    .retro-table td {
      padding: 5px !important;
    }

    .img-miniatura {
      cursor: pointer;
      transition: transform 0.2s;
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      object-fit: cover;
    }

    .img-miniatura:hover {
      transform: scale(1.05);
    }

    .click-marquee {
      border: 1px solid #000;
      margin-top: 5px;
    }

    .click-text {
      color: #000;
      font-weight: bold;
      font-size: 20px;
      font-family: Arial;
    }

    /* --- ESTILOS DEL VISOR (RESPONSIVE) --- */
    #visor-superpuesto {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.85);
      z-index: 9999999;
      justify-content: center;
      align-items: center;
    }

    .contenido-visor {
      background-color: #c0c0c0;
      border-top: 4px solid #fff;
      border-left: 4px solid #fff;
      border-bottom: 4px solid #555;
      border-right: 4px solid #555;
      padding: 2px;
      box-shadow: 10px 10px 0px rgba(0, 0, 0, 0.5);
      display: flex;
      flex-direction: column;
      width: 90%;
      max-width: 800px;
      height: auto;
      max-height: 85vh;
    }

    .visor-header {
      background-color: darkblue;
      color: white;
      padding: 4px 6px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: "Arial", sans-serif;
      font-size: 14px;
      font-weight: bold;
    }

    .visor-body {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding: 20px 10px;
      background-color: #555;
      margin: 5px;
      flex-grow: 1;
    }

    #foto-grande {
      max-width: 100%;
      max-height: 60vh;
      border: 3px inset #fff;
      object-fit: contain;
    }

    .btn-retro {
      background-color: #c0c0c0;
      border-top: 2px solid #fff;
      border-left: 2px solid #fff;
      border-bottom: 2px solid #000;
      border-right: 2px solid #000;
      color: #000;
      font-family: Arial, sans-serif;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-retro:active {
      border-top: 2px solid #000;
      border-left: 2px solid #000;
      border-bottom: 2px solid #fff;
      border-right: 2px solid #fff;
    }

    #btn-cerrar {
      width: 20px;
      height: 20px;
      padding: 0;
      line-height: 14px;
    }

    .btn-nav {
      all: unset;
      cursor: pointer;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      scale: 1.5;
      z-index: 10;
    }

    #btn-prev {
      left: -5rem;
    }

    #btn-next {
      right: -5rem;
    }

    #contador-visor {
      text-align: center;
      padding: 5px;
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #000;
    }

    @media (max-width: 900px) {
      #btn-prev {
        left: 30px;
        padding: 5px;
        border-radius: 4px;
        top: 90%;
        position: fixed;
      }

      #btn-next {
        right: 30px;
        padding: 5px;
        border-radius: 4px;
        top: 90%;
        position: fixed;
      }

      .contenido-visor {
        width: 95%;
      }

      .p2 {
        transform: translateY(-20px);
      }
    }
  </style>

  <script>
    function setupGallery() {
      const visor = document.getElementById("visor-superpuesto") as HTMLElement;
      const fotoGrande = document.getElementById(
        "foto-grande",
      ) as HTMLImageElement;
      const contadorVisor = document.getElementById(
        "contador-visor",
      ) as HTMLElement;
      const btnCerrar = document.getElementById("btn-cerrar");
      const btnNext = document.getElementById("btn-next");
      const btnPrev = document.getElementById("btn-prev");

      const listaFotos = [
        "/assets/ev1.png",
        "/assets/ev2.png",
        "/assets/ev3.png",
        "/assets/ev4.png",
        "/assets/ev5.png",
        "/assets/ev6.png",
        "/assets/ev7.png",
        "/assets/ev8.png",
        "/assets/ev9.png",
        "/assets/ev10.png",
      ];

      let indiceActual = 0;

      function actualizarImagen() {
        const ruta = listaFotos[indiceActual];
        fotoGrande.src = ruta;
        contadorVisor.innerHTML = `Archivo: ${ruta.split("/").pop()} | Foto ${indiceActual + 1} de ${listaFotos.length}`;
      }

      function mostrarFoto(urlFotoGrande: string) {
        indiceActual = listaFotos.indexOf(urlFotoGrande);
        actualizarImagen();
        visor.style.display = "flex";
        document.body.style.overflow = "hidden";
      }

      function cerrarVisor() {
        visor.style.display = "none";
        fotoGrande.src = "";
        document.body.style.overflow = "auto";
      }

      function fotoSiguiente() {
        indiceActual =
          indiceActual >= listaFotos.length - 1 ? 0 : indiceActual + 1;
        actualizarImagen();
      }

      function fotoAnterior() {
        indiceActual =
          indiceActual <= 0 ? listaFotos.length - 1 : indiceActual - 1;
        actualizarImagen();
      }

      document.querySelectorAll(".gallery-trigger").forEach((el) => {
        el.addEventListener("click", () => {
          const url = (el as HTMLElement).dataset.url;
          if (url) mostrarFoto(url);
        });
      });

      btnCerrar?.addEventListener("click", cerrarVisor);
      btnNext?.addEventListener("click", fotoSiguiente);
      btnPrev?.addEventListener("click", fotoAnterior);

      visor?.addEventListener("click", (e) => {
        if (e.target === visor) cerrarVisor();
      });
    }

    setupGallery();
    document.addEventListener("astro:after-swap", setupGallery);
  </script>
</Layout>
