---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Memoria de dirección | Segundo Cielo Dossier">
  <section id="sinopsis">
    <a href="/" class="h1">
      <hgroup>
        <h1>Segundo Cielo</h1>
      </hgroup>
    </a>

    <img
      src="https://blob.gifcities.org/gifcities/7KQMATCPWZ2VU2QTTYFTJRYP6ZUNPPQS.gif"
      alt=""
      style="position: absolute; top: 50%; left: 40%"
    />

    <div class="book-container">
      <div class="book">
        <div class="paper" id="p1" style="z-index: 4">
          <div
            class="front"
            style="
              display: flex;
              align-items: center;
              justify-content: center;
              background-position: center;
              border-left: 5px solid #a3957a;
            "
          >
            <h2
              style="
                font-family: 'Courier New', Courier, monospace;
                letter-spacing: 5px;
                color: #000000e0;
                border: 2px solid #000000e0;
                padding: 15px;
              "
            >
              MEMORIA
            </h2>
          </div>
          <div class="back">
            <p>
              Este cortometraje parte de una idea clara: explorar un
              momento específico en la historia reciente de internet en el
              que la tecnología no estaba completamente asimilada, y por
              tanto conservaba una cierta aura de misterio.
            </p>
            <p>
              A diferencia del presente, atravesado por la sospecha
              constante, hubo un tiempo en el que navegar implicaba una
              forma distinta de relación con lo desconocido, más
              permeable.
            </p>
            <div class="page-number">1</div>
          </div>
        </div>

        <div class="paper" id="p2" style="z-index: 3">
          <div class="front">
            <p>
              En ese contexto, las páginas web primitivas —de estética
              caótica, gifs animados y apariencia amateur— se convierten
              en espacios especialmente sugestivos: lugares donde lo
              espiritual, lo conspiranoico y lo íntimo se entrelazan sin
              jerarquías claras.
            </p>
            <p>
              Bajo su superficie ingenua, estos entornos proponen
              discursos fragmentados, incompletos, que invitan a
              permanecer, a profundizar.
            </p>
            <div class="page-number">2</div>
          </div>
          <div class="back">
            <p>
              En el centro del relato está Lucía, una mujer atravesada por
              la pérdida, cuya experiencia de duelo deriva en aislamiento,
              depresión y una desconexión progresiva de su entorno,
              especialmente de su pareja.
            </p>
            <p>
              El ordenador se convierte en su principal vía de escape, y
              estos espacios digitales en una segunda casa donde volcarse
              y disociar.
            </p>
            <div class="page-number">3</div>
          </div>
        </div>

        <div class="paper" id="p3" style="z-index: 2">
          <div class="front">
            <p>
              La película adopta un ritmo pausado pero sostenido, marcado
              por la repetición de los rituales y el deterioro de la
              relación. Los silencios y el sonido constante del ordenador
              construyen una atmósfera densa.
            </p>
            <p>
              A nivel formal, la combinación de rodaje en 16mm con
              imágenes de webcam de la época refuerza la dualidad entre lo
              físico y lo digital, donde la frontera entre refugio y
              pérdida termina por desdibujarse.
            </p>
            <div class="page-number">4</div>
          </div>
          <div class="back">
            <div class="page-number">5</div>
          </div>
        </div>

        <div class="paper" id="p4" style="z-index: 1">
          <div
            class="front"
            style="
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <h3
              style="
                font-family: 'Times New Roman', Times, serif;
                font-style: italic;
                color: #000000e0;
                padding: 5px 10px;
              "
            >
              THE END
            </h3>
          </div>
          <div class="back"></div>
        </div>
      </div>
    </div>

    <div class="book-controls">
      <button
        id="btn-prev-book"
        class="btn-book"
        disabled
      >
        <img
          src="https://web.archive.org/web/20091024115022im_/http://www.geocities.com/guitarfaerie/SDS-GGSaf-Back.gif"
          alt=""
        />
      </button>
      <button id="btn-next-book" class="btn-book">
        <img
          src="https://web.archive.org/web/20091024115022im_/http://www.geocities.com/guitarfaerie/next.gif"
          alt=""
        />
      </button>
    </div>
  </section>
</Layout>

<style>
  /* ESTRUCTURA DEL LIBRO EN 3D */
  .book-container {
    position: relative;
    width: 100%;
    max-width: 700px;
    height: 50vh;
    margin: 3rem auto 2rem auto;
    perspective: 1500px; /* Da la sensación de profundidad 3D */
  }

  .book {
    position: relative;
    width: 95%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.5s;
  }

  /* Estilos generales para cada hoja */
  .paper {
    position: absolute;
    width: 50%; /* Cada hoja ocupa la mitad del contenedor */
    height: 100%;
    top: 0;
    right: 0;
    transform-origin: left center; /* El eje de giro es el centro del libro */
    transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.645, 0.045, 0.355, 1);
    z-index: 1;
    
    /* 1. FUERZA AL NAVEGADOR A USAR LA GPU PARA EVITAR PARPADEOS */
    will-change: transform;
    -webkit-font-smoothing: antialiased;
  }

  /* Cara delantera y trasera de cada hoja */
  .front,
  .back {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background-color: #f4ecd8; /* Color papel viejo/misterioso */
    box-sizing: border-box;
    padding: 25px;
    backface-visibility: hidden; /* Oculta la cara de atrás cuando se gira */
    -webkit-backface-visibility: hidden; /* Soporte para Safari */
    box-shadow: inset 3px 0px 20px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    background: url("https://img.freepik.com/foto-gratis/fondo-textura-hormigon-vineta-amarillo-pastel_53876-124561.jpg?semt=ais_hybrid&w=740&q=80");
    background-position: center;
    
    /* 2. REFUERZA LA COLOCACIÓN PLANAR PARA QUE NINGÚN ELEMENTO TRASPASE */
    transform: translateZ(0);
  }

  .front {
    border-radius: 0 10px 10px 0;
    z-index: 2;
    cursor: pointer; /* Cursor de mano para invitar al clic */
  }

  .back {
    border-radius: 10px 0 0 10px;
    transform: rotateY(180deg) translateZ(0.1px); /* 3. EL TRUCO DEL TRANSLATE Z PARA SEPARAR CAPAS */
    z-index: 1;
    cursor: pointer; /* Cursor de mano para invitar al clic */
  }

  /* Contenido dentro de las páginas */
  .front p,
  .back p {
    font-family: "Times New Roman", Times, serif;
    font-size: 18px;
    line-height: 1.5;
    color: #1a1a1a;
    margin-bottom: 10px;
    text-align: justify;
  }

  .page-number {
    position: absolute;
    bottom: 10px;
    font-size: 11px;
    color: #777;
    font-family: Arial, sans-serif;
    opacity: 0;
  }
  .front .page-number {
    right: 15px;
  }
  .back .page-number {
    left: 15px;
  }

  /* CLASES DE ANIMACIÓN */
  .paper.flipped {
    transform: rotateY(-180deg);
  }

  /* CONTROLES DEL LIBRO */
  .book-controls {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 1rem;
  }

  .btn-book {
    all: unset;
    color: #000;
    font-family: Arial, sans-serif;
    font-size: 14px;
    font-weight: bold;
    cursor: pointer;
    padding: 5px 15px;
  }

  .btn-book img {
    pointer-events: none;
  }

  .btn-book:active {
    scale: 0.8;
  }

  .btn-book:disabled {
    color: #808080;
    cursor: not-allowed;
  }
</style>

<script>
  function setupBook() {
    let currentLocation = 1;
    const numOfPapers = 4;
    const maxLocation = numOfPapers + 1;

    const prevBtn = document.querySelector("#btn-prev-book") as HTMLButtonElement;
    const nextBtn = document.querySelector("#btn-next-book") as HTMLButtonElement;

    const paper1 = document.querySelector("#p1") as HTMLElement;
    const paper2 = document.querySelector("#p2") as HTMLElement;
    const paper3 = document.querySelector("#p3") as HTMLElement;
    const paper4 = document.querySelector("#p4") as HTMLElement;

    if (!prevBtn || !nextBtn || !paper1 || !paper2 || !paper3 || !paper4) return;

    // LIMPIEZA INICIAL: Clave para Astro (evita que se queden guardadas transiciones anteriores)
    currentLocation = 1;
    const papers = [paper1, paper2, paper3, paper4];
    papers.forEach(p => p.classList.remove("flipped"));
    paper1.style.zIndex = "4";
    paper2.style.zIndex = "3";
    paper3.style.zIndex = "2";
    paper4.style.zIndex = "1";
    prevBtn.setAttribute("disabled", "true");
    nextBtn.removeAttribute("disabled");

    function goNextPage() {
      if (currentLocation < maxLocation) {
        switch (currentLocation) {
          case 1:
            paper1.classList.add("flipped");
            setTimeout(() => { paper1.style.zIndex = "1"; }, 300); // 4. RETARDO SUAVE DE Z-INDEX
            prevBtn.removeAttribute("disabled");
            break;
          case 2:
            paper2.classList.add("flipped");
            setTimeout(() => { paper2.style.zIndex = "2"; }, 300);
            break;
          case 3:
            paper3.classList.add("flipped");
            setTimeout(() => { paper3.style.zIndex = "3"; }, 300);
            break;
          case 4:
            paper4.classList.add("flipped");
            setTimeout(() => { paper4.style.zIndex = "4"; }, 300);
            nextBtn.setAttribute("disabled", "true");
            break;
        }
        currentLocation++;
      }
    }

    function goPrevPage() {
      if (currentLocation > 1) {
        switch (currentLocation) {
          case 2:
            paper1.classList.remove("flipped");
            paper1.style.zIndex = "4";
            prevBtn.setAttribute("disabled", "true");
            break;
          case 3:
            paper2.classList.remove("flipped");
            paper2.style.zIndex = "3";
            break;
          case 4:
            paper3.classList.remove("flipped");
            paper3.style.zIndex = "2";
            break;
          case 5:
            paper4.classList.remove("flipped");
            paper4.style.zIndex = "1";
            nextBtn.removeAttribute("disabled");
            break;
        }
        currentLocation--;
      }
    }

    // Clonamos los nodos para evitar que se dupliquen los Event Listeners en Astro al navegar
    const newPrevBtn = prevBtn.cloneNode(true) as HTMLButtonElement;
    const newNextBtn = nextBtn.cloneNode(true) as HTMLButtonElement;
    prevBtn.parentNode?.replaceChild(newPrevBtn, prevBtn);
    nextBtn.parentNode?.replaceChild(newNextBtn, nextBtn);

    newPrevBtn.addEventListener("click", goPrevPage);
    newNextBtn.addEventListener("click", goNextPage);

    papers.forEach((paper) => {
      const front = paper.querySelector(".front");
      if (front) {
        // Clonamos para limpiar eventos
        const newFront = front.cloneNode(true);
        front.parentNode?.replaceChild(newFront, front);
        newFront.addEventListener("click", goNextPage);
      }
      const back = paper.querySelector(".back");
      if (back) {
        // Clonamos para limpiar eventos
        const newBack = back.cloneNode(true);
        back.parentNode?.replaceChild(newBack, back);
        newBack.addEventListener("click", goPrevPage);
      }
    });
  }

  setupBook();
  document.addEventListener('astro:after-swap', setupBook);
</script>