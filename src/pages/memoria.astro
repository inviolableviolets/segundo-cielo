---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Memoria de dirección | Segundo Cielo Dossier">
  <section id="sinopsis">
    <a href="/" class="h1">
      <hgroup>
        <h1>Segundo Cielo</h1>
      </hgroup>
    </a>

    <img
      src="https://blob.gifcities.org/gifcities/7KQMATCPWZ2VU2QTTYFTJRYP6ZUNPPQS.gif"
      alt=""
      class="bg-gif"
    />

    <div class="book-container">
      <div class="book">
        <div class="paper" id="p1" style="z-index: 4">
          <div
            class="front"
            style="
              display: flex;
              align-items: center;
              justify-content: center;
              background-position: center;
              border-left: 5px solid #a3957a;
            "
          >
            <h2
              style="
                font-family: 'Courier New', Courier, monospace;
                letter-spacing: 5px;
                color: #000000e0;
                border: 2px solid #000000e0;
                padding: 15px;
              "
              class="cover-title"
            >
              MEMORIA
            </h2>
          </div>
          <div class="back">
            <p>
              Este cortometraje parte de una idea clara: explorar un momento
              específico en la historia reciente de internet en el que la
              tecnología no estaba completamente asimilada, y por tanto
              conservaba una cierta aura de misterio.
            </p>
            <p>
              A diferencia del presente, atravesado por la sospecha constante,
              hubo un tiempo en el que navegar implicaba una forma distinta de
              relación con lo desconocido, más permeable.
            </p>
            <div class="page-number">1</div>
          </div>
        </div>

        <div class="paper" id="p2" style="z-index: 3">
          <div class="front">
            <p>
              En ese contexto, las páginas web primitivas —de estética caótica,
              gifs animados y apariencia amateur— se convierten en espacios
              especialmente sugestivos: lugares donde lo espiritual, lo
              conspiranoico y lo íntimo se entrelazan sin jerarquías claras.
            </p>
            <p>
              Bajo su superficie ingenua, estos entornos proponen discursos
              fragmentados, incompletos, que invitan a permanecer, a
              profundizar.
            </p>
            <div class="page-number">2</div>
          </div>
          <div class="back">
            <p>
              En el centro del relato está Lucía, una mujer atravesada por la
              pérdida, cuya experiencia de duelo deriva en aislamiento,
              depresión y una desconexión progresiva de su entorno,
              especialmente de su pareja.
            </p>
            <p>
              El ordenador se convierte en su principal vía de escape, y estos
              espacios digitales en una segunda casa donde volcarse y disociar.
            </p>
            <div class="page-number">3</div>
          </div>
        </div>

        <div class="paper" id="p3" style="z-index: 2">
          <div class="front">
            <p>
              La película adopta un ritmo pausado pero sostenido, marcado por la
              repetition de los rituales y el deterioro de la relación. Los
              silencios y el sonido constante del ordenador construyen una
              atmósfera densa.
            </p>
            <p>
              A nivel formal, la combinación de rodaje en 16mm con imágenes de
              webcam de la época refuerza la dualidad entre lo físico y lo
              digital, donde la frontera entre refugio y pérdida termina por
              desdibujarse.
            </p>
            <div class="page-number">4</div>
          </div>
          <div class="back">
            <p style="text-align: center; margin-top: 30%;"></p>
            <div class="page-number">5</div>
          </div>
        </div>

        <div class="paper" id="p4" style="z-index: 1">
          <div
            class="front"
            style="
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            <h3
              style="
                font-family: 'Times New Roman', Times, serif;
                font-style: italic;
                color: #000000e0;
                padding: 5px 10px;
                font-size: 2rem;
              "
            >
              THE END
            </h3>
          </div>
          <div class="back"></div>
        </div>
      </div>
    </div>

    <div class="book-controls">
      <button id="btn-prev-book" class="btn-book" disabled>
        <img
          src="https://web.archive.org/web/20091024115022im_/http://www.geocities.com/guitarfaerie/SDS-GGSaf-Back.gif"
          alt="Atrás"
        />
      </button>
      <button id="btn-next-book" class="btn-book">
        <img
          src="https://web.archive.org/web/20091024115022im_/http://www.geocities.com/guitarfaerie/next.gif"
          alt="Adelante"
        />
      </button>
    </div>
  </section>
</Layout>

<style>
  /* --- ESTILOS ESCRITORIO (BASE) --- */
  .bg-gif {
    position: absolute;
    top: 50%;
    left: 40%;
    z-index: 0;
  }

  .book-container {
    position: relative;
    width: 100%;
    max-width: 700px;
    height: 50vh;
    margin: 3rem auto 2rem auto;
    perspective: 1500px;
    z-index: 1;
  }

  .book {
    position: relative;
    width: 95%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.5s;
  }

  .paper {
    position: absolute;
    width: 50%;
    height: 100%;
    top: 0;
    right: 0;
    transform-origin: left center;
    transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.645, 0.045, 0.355, 1);
    z-index: 1;
  }

  .front,
  .back {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background-color: #f4ecd8;
    box-sizing: border-box;
    padding: 25px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    box-shadow: inset 3px 0px 20px rgba(0, 0, 0, 0.1);
    overflow-y: auto;
    background: url("https://img.freepik.com/foto-gratis/fondo-textura-hormigon-vineta-amarillo-pastel_53876-124561.jpg?semt=ais_hybrid&w=740&q=80");
    background-position: center;
    transform: translateZ(0);
  }

  .front {
    border-radius: 0 10px 10px 0;
    z-index: 2;
    cursor: pointer;
  }

  .back {
    border-radius: 10px 0 0 10px;
    transform: rotateY(180deg) translateZ(0.1px);
    z-index: 1;
    cursor: pointer;
  }

  .front p,
  .back p {
    font-family: "Times New Roman", Times, serif;
    font-size: 18px;
    line-height: 1.5;
    color: #1a1a1a;
    margin-bottom: 10px;
    text-align: justify;
  }

  .page-number {
    position: absolute;
    bottom: 10px;
    font-size: 11px;
    color: #777;
    font-family: Arial, sans-serif;
    opacity: 0;
  }

  .front .page-number {
    right: 15px;
  }
  .back .page-number {
    left: 15px;
  }

  .paper.flipped {
    transform: rotateY(-180deg);
  }

  .book-controls {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 1rem;
    position: relative;
    z-index: 10;
  }

  .btn-book {
    all: unset;
    cursor: pointer;
    padding: 5px 15px;
  }

  .btn-book:active {
    scale: 0.8;
  }
  .btn-book:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* --- ADAPTACIÓN MÓVIL BRUTA (< 900px) --- */
  @media (max-width: 900px) {
    .bg-gif {
      left: 50px;
      top: 50%;
      width: 80px;
    }

    /* El contenedor ahora mide el 90% del ancho de la pantalla */
    .book-container {
      width: 90vw !important;
      max-width: none;
      height: 45vh; /* Ajustamos la altura para que las proporciones del libro no se estiren */
      margin: 2rem auto 1rem auto;
      perspective: 2000px;
    }

    .book {
      width: 100%;
    }

    /* Las hojas vuelven a ser el 50% del contenedor padre (es decir, el 45% de la pantalla) */
    .paper {
      width: 50%;
      right: 0;
      left: auto;
      transform-origin: left center; /* Volvemos al giro de libro lateral */
    }

    .paper.flipped {
      transform: rotateY(-180deg);
    }

    .back {
      transform: rotateY(180deg) translateZ(0.1px);
    }

    .front,
    .back {
      padding: 10px; /* Padding muy estrecho para exprimir el espacio */
    }

    .front p,
    .back p {
      font-size: 3vw;
      line-height: 1.3;
      margin-bottom: 6px;
    }

    .cover-title {
      font-size: 3.5vw !important;
      padding: 5px !important;
      letter-spacing: 2px !important;
    }
  }
</style>

<script>
  function setupBook() {
    let currentLocation = 1;
    const numOfPapers = 4;
    const maxLocation = numOfPapers + 1;

    const prevBtn = document.querySelector(
      "#btn-prev-book",
    ) as HTMLButtonElement;
    const nextBtn = document.querySelector(
      "#btn-next-book",
    ) as HTMLButtonElement;

    const paper1 = document.querySelector("#p1") as HTMLElement;
    const paper2 = document.querySelector("#p2") as HTMLElement;
    const paper3 = document.querySelector("#p3") as HTMLElement;
    const paper4 = document.querySelector("#p4") as HTMLElement;

    if (!prevBtn || !nextBtn || !paper1 || !paper2 || !paper3 || !paper4)
      return;

    const papers = [paper1, paper2, paper3, paper4];

    currentLocation = 1;
    papers.forEach((p) => p.classList.remove("flipped"));
    paper1.style.zIndex = "4";
    paper2.style.zIndex = "3";
    paper3.style.zIndex = "2";
    paper4.style.zIndex = "1";
    prevBtn.disabled = true;
    nextBtn.disabled = false;

    function updateView() {
      prevBtn.disabled = currentLocation === 1;
      nextBtn.disabled = currentLocation === maxLocation;
    }

    function goNextPage() {
      if (currentLocation < maxLocation) {
        switch (currentLocation) {
          case 1:
            paper1.classList.add("flipped");
            setTimeout(() => {
              paper1.style.zIndex = "1";
            }, 300);
            break;
          case 2:
            paper2.classList.add("flipped");
            setTimeout(() => {
              paper2.style.zIndex = "2";
            }, 300);
            break;
          case 3:
            paper3.classList.add("flipped");
            setTimeout(() => {
              paper3.style.zIndex = "3";
            }, 300);
            break;
          case 4:
            paper4.classList.add("flipped");
            setTimeout(() => {
              paper4.style.zIndex = "4";
            }, 300);
            break;
        }
        currentLocation++;
        updateView();
      }
    }

    function goPrevPage() {
      if (currentLocation > 1) {
        switch (currentLocation) {
          case 2:
            paper1.classList.remove("flipped");
            setTimeout(() => {
              paper1.style.zIndex = "4";
            }, 300);
            break;
          case 3:
            paper2.classList.remove("flipped");
            setTimeout(() => {
              paper2.style.zIndex = "3";
            }, 300);
            break;
          case 4:
            paper3.classList.remove("flipped");
            setTimeout(() => {
              paper3.style.zIndex = "2";
            }, 300);
            break;
          case 5:
            paper4.classList.remove("flipped");
            setTimeout(() => {
              paper4.style.zIndex = "1";
            }, 300);
            break;
        }
        currentLocation--;
        updateView();
      }
    }

    prevBtn.removeEventListener("click", goPrevPage);
    nextBtn.removeEventListener("click", goNextPage);
    prevBtn.addEventListener("click", goPrevPage);
    nextBtn.addEventListener("click", goNextPage);

    papers.forEach((paper) => {
      const front = paper.querySelector(".front");
      const back = paper.querySelector(".back");

      if (front) {
        front.removeEventListener("click", goNextPage);
        front.addEventListener("click", goNextPage);
      }
      if (back) {
        back.removeEventListener("click", goPrevPage);
        back.addEventListener("click", goPrevPage);
      }
    });
  }

  setupBook();
  document.addEventListener("astro:after-swap", setupBook);
</script>
