---
import GuardaMovil from "./GuardaMovil.astro"; // Asegúrate de que la ruta sea correcta
---

<div class="modal">
  <img
    src="https://blob.gifcities.org/gifcities/VF4XAPQCAXGGU4R3Z54CQGTMDNIEO5J3.gif"
    alt=""
    class="img-modal"
  />

  <div
    id="modal-base-content"
    style="display: flex; flex-direction: column; align-items: center;"
  >
    <p>SEGUNDO CIELO</p>
    <button id="close-modal">LLEVAME ALLi</button>
    <div class="cross">✟</div>
  </div>

  <GuardaMovil />
</div>

<script is:inline>
  function setupModal() {
    const modal = document.querySelector(".modal");
    const button = document.getElementById("close-modal");
    // Referencias nuevas para la guarda
    const mainContent = document.getElementById("modal-base-content");
    const guarda = document.getElementById("guarda-movil");

    if (!modal || !button) return;

    if (window.modalYaVistoEnEstaNavegacion) {
      modal.style.display = "none";
      modal.style.visibility = "hidden";
      return;
    } else {
      modal.style.display = "flex";
    }

    button.replaceWith(button.cloneNode(true));
    const activeButton = document.getElementById("close-modal");

    // Función que contiene tu lógica de cierre original
    function ejecutarCierreOriginal() {
      window.modalYaVistoEnEstaNavegacion = true;

      const audioPrincipal = document.getElementById("musica-fondo");
      if (audioPrincipal) {
        audioPrincipal
          .play()
          .catch((err) =>
            console.log("El navegador bloqueó el autoplay:", err),
          );
      }

      modal.style.transition =
        "transform 0.4s cubic-bezier(0.36, 0, 0.66, -0.56)";
      modal.style.transformOrigin = "center center";
      modal.style.transform = "scale(0)";
      modal.style.pointerEvents = "none";

      modal.addEventListener(
        "transitionend",
        () => {
          modal.style.visibility = "hidden";
          modal.style.display = "none";
        },
        { once: true },
      );
    }

    activeButton?.addEventListener("click", function () {
      // SI ES MÓVIL: Mostramos la guarda y NO cerramos todavía
      if (window.innerWidth < 900) {
        mainContent.style.display = "none";
        guarda.style.display = "flex";
      } else {
        // SI ES PC: Tu lógica de siempre
        ejecutarCierreOriginal();
      }
    });

    // Escuchamos el botón final de la guarda para cerrar el modal de verdad
    document
      .getElementById("btn-final-guarda")
      ?.addEventListener("click", () => {
        ejecutarCierreOriginal();
      });
  }

  setupModal();
  document.addEventListener("astro:after-swap", setupModal);
</script>

<style>
  /* --- TU CSS ORIGINAL SIN TOCAR NI UNA LÍNEA --- */
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    width: 100vw;
    height: 100vh;
    font-size: 5rem;
    z-index: 9999999999999;
    background: #224482;
  }

  #close-modal {
    all: unset;
    text-decoration: underline;
    text-shadow: 0 0 10px yellow;
    font-style: italic;
    font-family: "Comic Sans MS", "Comic Sans", cursive !important;
    display: inline;
    border-radius: 100%;
    font-size: 3rem;
    cursor: pointer;
    color: white;
  }

  #close-modal:hover {
    border-radius: 0;
    text-shadow: 0 0 10px yellow;
    font-weight: bolder;
    font-style: normal;
    font-size: 3.2rem;
  }

  .modal p {
    font-size: 8rem;
    background: -webkit-linear-gradient(#000dff, #06fcae);
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-shadow: 0 0 10px white;
    text-align: center;
  }

  .modal div.cross {
    text-shadow: 0 0 10px white;
    font-size: 7rem;
    position: absolute;
    top: 62%;
    left: 48%;
    transform: translate(-50%, -50%);
  }

  .modal .img-modal {
    width: 100vw;
    height: 100vh;
    position: absolute;
    top: 0;
    left: 0;
    z-index: -1;
  }

  .modal .cross {
    animation: heartbeat 1s infinite;
  }

  @keyframes heartbeat {
    0% {
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.2);
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  /* --- MEDIA QUERY --- */
  @media (max-width: 900px) {
    .modal p {
      font-size: 4rem !important;
    }

    .modal #close-modal {
      font-size: 1.5rem !important;
      margin-top: 1rem !important;
      letter-spacing: 3px !important;
    }

    .modal div.cross {
      font-size: 3rem !important;
      top: 70% !important;
      left: 50% !important;
      /* Cambiamos la animación por una versión que mantenga el tamaño pequeño en móvil */
      animation: heartbeat-mobile 1s infinite !important;
    }
  }

  /* Animación especial para móvil que no destruye el translate de la cruz */
  @keyframes heartbeat-mobile {
    0% {
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.1);
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
    }
  }
</style>
