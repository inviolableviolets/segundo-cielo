---
const { pathname } = Astro.url;

const links = [
  { href: "/sinopsis", label: "Sinopsis" },
  { href: "/personajes", label: "Personajes" },
  { href: "/memoria", label: "Memoria de dirección" },
  { href: "/direccion", label: "Directores" },
  { href: "/talento", label: "Talento" },
  { href: "/bso", label: "Banda sonora" },
  { href: "/referencias", label: "Referencias" },
  { href: "/fisicos", label: "Espacios físicos" },
  { href: "/virtuales", label: "Espacios virtuales" },
];

function isActive(href: string) {
  return pathname === href || pathname === `${href}/`;
}
---

<div class="mobile-top-bar">
  <button id="hamburger-btn" aria-label="Abrir menú">
    <img
      src="https://blob.gifcities.org/gifcities/XTQOS367RTEUD77FTEZ32NBVHPDF7BZQ.gif"
      alt=""
    />
  </button>
</div>

<div id="sidebar-overlay" class="overlay"></div>

<aside id="main-sidebar">
  <button
    id="close-sidebar-btn"
    class="mobile-close-btn"
    aria-label="Cerrar menú">
    <img src="https://blob.gifcities.org/gifcities/2QIVZLKKSKNPM7MK2ICJYQYFVULMOMCQ.gif" alt=""></button
  >

  <img
    src="https://blob.gifcities.org/gifcities/AX2JFASE63DASLDA3KPBS3WO7F5UUXED.gif"
    alt=""
    class="aside-main-img"
  />
  <img
    src="https://blob.gifcities.org/gifcities/DRVXJYEPXMTKQLNRA2CXSTXSZRRCEUYD.gif"
    alt=""
    class="god-loves-you-gif"
  />
  <ul>
    {
      links.map((link) => (
        <li>
          <a href={link.href} class={isActive(link.href) ? "active" : ""}>
            {link.label}
          </a>
        </li>
      ))
    }
    <li>
      <a href="/contactanos" class={isActive("/contactanos") ? "active" : ""}>
        <img
          src="https://blob.gifcities.org/gifcities/SDDJOMZJXZPAZWS6T2KYS7Z34YPNNZ7R.gif"
          alt=""
          width="35%"
        />
      </a>
    </li>
  </ul>
</aside>

<script is:inline>
  // Delegación de eventos infalible
  if (!window.sidebarEventsLoaded) {
    document.addEventListener("click", (e) => {
      const sidebar = document.getElementById("main-sidebar");
      const overlay = document.getElementById("sidebar-overlay");

      if (!sidebar || !overlay) return;

      const isHamburger = e.target.closest("#hamburger-btn");
      const isCloseBtn = e.target.closest("#close-sidebar-btn");
      const isOverlay = e.target === overlay;
      const isLink =
        e.target.tagName === "A" && sidebar.classList.contains("open");

      // Abrir
      if (isHamburger) {
        sidebar.classList.add("open");
        overlay.classList.add("visible");
      }

      // Cerrar (Por la X, por el overlay o por pinchar un enlace)
      else if (isCloseBtn || isOverlay || isLink) {
        sidebar.classList.remove("open");
        overlay.classList.remove("visible");
      }
    });

    window.sidebarEventsLoaded = true;
  }
</script>

<style>
  /* --- ESTILOS ORIGINALES INTACTOS AL 100% --- */
  aside {
    background: radial-gradient(darkblue, rgb(160, 160, 221), blue);
    height: 100vh;
    width: 20vw;
    position: sticky;
    top: 0;
    left: 0;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 1000;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  aside .aside-main-img {
    width: 100%;
    margin-top: -1rem;
  }

  aside ul {
    color: var(--color-white);
    padding-top: 4rem;
    font-family: var(--font-serif);
    list-style-type: none;
    width: 100%;
  }

  /* Aquí están tus medidas originales sin tocar */
  aside li {
    font-size: 1.4rem;
    padding: 0 0.5rem 0.25rem 0.5rem;
    text-transform: uppercase;
    font-style: italic;
  }

  @media (max-width: 900px) {
    aside li {
      font-size: 0.8rem;
      padding: 0 0.5rem 0.1rem 0.5rem;
    }
  }

  aside li:hover {
    color: var(--color-yellow) !important;
  }

  aside li a:not(.active):hover {
    color: var(--color-cyan) !important;
  }

  aside li::before {
    content: "❤︎⁠";
    margin-right: 10px;
    font-size: 18px;
    color: var(--color-yellow);
  }

  aside .god-loves-you-gif {
    width: 70%;
    padding-top: 4rem;
    filter: hue-rotate(120deg) brightness(200%);
    opacity: 0.4;
    margin-top: -3rem;
    margin-bottom: -3rem;
  }

  a.active {
    color: var(--color-yellow);
    font-weight: bolder !important;
  }

  a {
    text-decoration: underline;
    color: inherit;
  }

  /* Elementos ocultos en PC */
  .mobile-top-bar,
  .overlay,
  .mobile-close-btn {
    display: none;
  }

  /* --- ADAPTACIÓN MÓVIL BRUTA (< 900px) --- */
  @media (max-width: 900px) {
    /* Barra superior */
    .mobile-top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 55px;
      padding: 0 1rem;
      box-sizing: border-box;
      z-index: 999;
      color: white;
    }

    .mobile-top-bar .site-title {
      font-family: var(--font-serif);
      font-size: 1.6rem;
      font-weight: bold;
      text-shadow: 2px 2px 0px blue;
    }

    /* Botón Hamburguesa Hostil */
    #hamburger-btn {
      all: unset;
      width: 80px;
      display: flex;
      flex-direction: column;
      justify-content: space-around;
      align-items: center;
      margin-top: 0.5rem;
      cursor: pointer;
      filter: drop-shadow(0 0 2px white);


      img {
        width: 100%;
      }
    }

    #hamburger-btn:active {
      border: 3px inset #fff;
    }

    .bar {
      width: 22px;
      height: 3px;
      background: black;
    }

    /* Botón de Cerrar (La X en la esquina superior del sidebar) */
    .mobile-close-btn {
      all: unset;
      display: block;
      top: 0;
      position: absolute;
      right: -0.5rem;
      scale: 0.5;
.      font-family: sans-serif;
      font-size: 2rem;
      font-weight: bold;
      text-align: center;
      line-height: 28px;
      cursor: pointer;
      z-index: 1001;
    }

    .mobile-close-btn:active {
      border: 3px inset #fff;
    }

    /* Transformación del Sidebar */
    aside {
      overflow: hidden;
      position: fixed;
      top: 0;
      left: 0;
      width: 60vw; /* Anchura en móvil */
      height: 100vh;
      transform: translateX(-100%); /* Escondido a la izquierda */
      box-shadow: 5px 0px 0px #000; /* Borde duro sin difuminar */
      z-index: 1000;
    }

    aside.open {
      transform: translateX(0); /* Deslizar hacia dentro */
    }

    /* Capa oscura (Fondo bloqueante) */
    .overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      z-index: 998;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .overlay.visible {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>
